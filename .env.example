# OPUS Mobile — Environment Variables
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to version control.

# ── API ──────────────────────────────────────────────────────────────────────
API_BASE_URL=https://api-dev.opus-mobile.app

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_CLIENT_ID=your_client_id_here
AUTH_CLIENT_SECRET=your_client_secret_here

# ── Storage ──────────────────────────────────────────────────────────────────
HIVE_ENCRYPTION_KEY=your_256bit_hex_key_here

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_LOGGING=true
